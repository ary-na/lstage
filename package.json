{
  "name": "@ariian/lstage",
  "version": "1.0.1",
  "description": "Interactive CLI tool to stage and unstage git files by number",
  "type": "module",
  "bin": {
    "lstage": "bin/index.js"
  },
  "files": [
    "dist/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "git",
    "cli",
    "staging",
    "terminal",
    "interactive",
    "git-add",
    "git-stage"
  ],
  "author": "arii",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ary-na/lstage.git"
  },
  "homepage": "https://github.com/ary-na/lstage#readme",
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.22.3",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "chalk": "^5.6.2"
  }
}
